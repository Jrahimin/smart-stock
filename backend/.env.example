APP_NAME=Smart Stock API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_stock
# Optional. If omitted, Alembic uses DATABASE_URL and converts it to asyncpg internally.
ALEMBIC_DATABASE_URL=

BACKEND_CORS_ORIGINS=http://localhost:3000
AUTH_ENABLED=false

