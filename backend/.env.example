APP_NAME=Smart Stock API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_stock
# Optional. If omitted, Alembic uses DATABASE_URL and converts it to asyncpg internally.
ALEMBIC_DATABASE_URL=

BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

JWT_SECRET_KEY=change-me-in-local-development-only
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

# OAuth (optional; must match frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID / NEXT_PUBLIC_FACEBOOK_APP_ID)
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# SMTP (optional; leave SMTP_HOST empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@smart-stock.local

# Bootstrap super admin (run: python -m app.scripts.seed_super_admin)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-local-only
SUPER_ADMIN_DISPLAY_NAME=Super Admin

# Process role: set true only in the dedicated scheduler container (or local single-process uvicorn).
# Docker backend-api uses RUN_SCHEDULER=false; backend-scheduler uses RUN_SCHEDULER=true.
RUN_SCHEDULER=false

# Production example (Docker):
# DATABASE_URL=postgresql://smartstock:SECRET@postgres:5432/smart_stock
# BACKEND_CORS_ORIGINS=https://stockwealthbd.com,https://www.stockwealthbd.com
# FRONTEND_BASE_URL=https://stockwealthbd.com
# RUN_SCHEDULER=false   # backend-api
# RUN_SCHEDULER=true    # backend-scheduler only

# Market schedulers (Asia/Dhaka times; can also be overridden in /admin/configuration)
DAILY_MARKET_SYNC_SCHEDULER_ENABLED=true
MARKET_SNAPSHOT_SCHEDULER_ENABLED=true
MARKET_OPEN_TIME=10:00
MARKET_CLOSE_TIME=15:00
MARKET_SNAPSHOT_INTERVAL_MINUTES=15
DAILY_MARKET_SYNC_TIME=15:15
DAILY_MARKET_PRIMARY_SOURCE=amarstock_latest_price_json
DAILY_MARKET_STOCKNOW_VALIDATION_ENABLED=false
DAILY_MARKET_STOCKNOW_FALLBACK_ENABLED=false

# Ingestion feature flags (can also be overridden in /admin/configuration)
AMARSTOCK_NEWS_INGESTION_ENABLED=true
AMARSTOCK_DAILY_LATEST_PRICE_PATCH_ENABLED=false
AMARSTOCK_INDEX_SUMMARY_ENABLED=true
AMARSTOCK_LATEST_PRICE_STOCK_DETAILS_ENABLED=true

# Stock details sync tuning
STOCK_DETAILS_SYNC_FREQUENCY_MONTHS=3
STOCK_DETAILS_SYNC_MAX_CONCURRENCY=3
STOCK_DETAILS_HISTORICAL_WINDOW_DAYS=90

# External data sources
AMARSTOCK_API_BASE_URL=https://www.amarstock.com
DSE_ARCHIVE_SSL_VERIFY=false
