NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Server-only internal API for dashboard core SSR (Next.js RSC; not exposed to browser)
SERVER_API_BASE_URL=http://localhost:8000/api/v1
# Optional: max wait for dashboard core SSR fetches (default 5000ms)
# DASHBOARD_CORE_LOADER_TIMEOUT_MS=5000
# Public site URL for canonical links, sitemap, and JSON-LD (production: https://stockwealthbd.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Long-lived IndexedDB TTL for non-market GETs (e.g. stock search)
NEXT_PUBLIC_MARKET_CACHE_HOURS=2
# Short-lived IndexedDB TTL for market intelligence pages (5–10 minutes)
NEXT_PUBLIC_MARKET_CACHE_MINUTES=10

# Production (Docker build-time — must be set when running `docker compose build`):
# NEXT_PUBLIC_API_BASE_URL=https://api.stockwealthbd.com/api/v1

# OAuth (optional; must match backend GOOGLE_CLIENT_ID / FACEBOOK_APP_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
# Google Analytics 4 measurement ID (optional; omit to disable GA)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Client-side feature flags
NEXT_PUBLIC_FEATURE_ADVANCED_CHART_OVERLAYS=false
NEXT_PUBLIC_FEATURE_ADVANCED_SCANNERS=false
NEXT_PUBLIC_FEATURE_BACKEND_SIGNAL_ENRICHMENT=false
