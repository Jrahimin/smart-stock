# Copy to `.env` in the repo root before running docker compose.
# Never commit `.env` — it is gitignored.
#
# This file feeds backend `Settings` via Docker Compose (see backend/docs/deployment_architecture.md
# — Configuration precedence). Keys here overlap with admin-editable operational settings; env
# wins at runtime until DB overrides are merged into get_settings().
# --- PostgreSQL ---
POSTGRES_USER=smartstock
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=smart_stock
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend (shared by backend-api and backend-scheduler) ---
APP_NAME=Smart Stock API
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ALEMBIC_DATABASE_URL=

# Optional — dashboard section cache (app works without Redis)
REDIS_URL=redis://redis:6379/0

BACKEND_CORS_ORIGINS=https://stockwealthbd.com,https://www.stockwealthbd.com
FRONTEND_BASE_URL=https://stockwealthbd.com

JWT_SECRET_KEY=change-me-long-random-production-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24

GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@stockwealthbd.com

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-before-bootstrap
SUPER_ADMIN_DISPLAY_NAME=Super Admin

MARKET_SNAPSHOT_SCHEDULER_ENABLED=true
DAILY_MARKET_SYNC_SCHEDULER_ENABLED=true
MARKET_OPEN_TIME=10:00
MARKET_CLOSE_TIME=15:00
MARKET_SNAPSHOT_INTERVAL_MINUTES=15
DAILY_MARKET_SYNC_TIME=15:15
DAILY_MARKET_PRIMARY_SOURCE=amarstock_latest_price_json
DAILY_MARKET_STOCKNOW_VALIDATION_ENABLED=false
DAILY_MARKET_STOCKNOW_FALLBACK_ENABLED=false

AMARSTOCK_NEWS_INGESTION_ENABLED=true
AMARSTOCK_DAILY_LATEST_PRICE_PATCH_ENABLED=false
AMARSTOCK_INDEX_SUMMARY_ENABLED=true
AMARSTOCK_LATEST_PRICE_STOCK_DETAILS_ENABLED=true

STOCK_DETAILS_SYNC_FREQUENCY_MONTHS=3
STOCK_DETAILS_SYNC_MAX_CONCURRENCY=3
STOCK_DETAILS_HISTORICAL_WINDOW_DAYS=90

AMARSTOCK_API_BASE_URL=https://www.amarstock.com
DSE_ARCHIVE_SSL_VERIFY=false

# Gunicorn (backend-api only)
WEB_CONCURRENCY=2
FORWARDED_ALLOW_IPS=127.0.0.1,172.28.0.0/16

# --- Frontend build args (used at `docker compose build`) ---
NEXT_PUBLIC_API_BASE_URL=https://api.stockwealthbd.com/api/v1
NEXT_PUBLIC_SITE_URL=https://stockwealthbd.com
NEXT_PUBLIC_MARKET_CACHE_HOURS=2
NEXT_PUBLIC_MARKET_CACHE_MINUTES=10
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=
NEXT_PUBLIC_FEATURE_ADVANCED_CHART_OVERLAYS=false
NEXT_PUBLIC_FEATURE_ADVANCED_SCANNERS=false
NEXT_PUBLIC_FEATURE_BACKEND_SIGNAL_ENRICHMENT=false

# --- Release metadata (set automatically by deploy/scripts/*.sh; override optional) ---
# APP_VERSION=2026.06.18.3
# GIT_SHA=7e2a9d1  # short SHA only (7 chars); full hashes are truncated automatically
# BUILD_TIME=2026-06-18T16:30:00Z

# --- Cloudflare (optional — enables automatic cache purge after deploy) ---
CF_API_TOKEN=
CF_ZONE_ID=
